{
  "name": "smartfound/backend",
  "description": "SmartFound Lost-and-Found Platform — UTM Backend",
  "type": "project",
  "require": {
    "php": ">=8.1",
    "slim/slim": "^4.12",
    "slim/psr7": "^1.6",
    "php-di/php-di": "^7.0",
    "firebase/php-jwt": "^6.10",
    "vlucas/phpdotenv": "^5.6",
    "league/oauth2-google": "^4.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "policy": {
    "advisories": {
      "block": false
    }
  },
  "scripts": {
    "start": "php -S localhost:8081 -t public",
    "test": "phpunit"
  }
}
